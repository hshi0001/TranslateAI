GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model. Translate app default is gemini-2.5-pro.
# GEMINI_MODEL=gemini-2.5-pro

# Translate app: JWT secret for session (use a long random string in production)
TRANSLATE_JWT_SECRET=your_secret_change_in_production

# Translate app: comma-separated admin emails (for editing user limits)
# TRANSLATE_ADMIN_EMAIL=admin@example.com

# Optional: Postgres (Neon/Vercel Postgres) so preset roles and account data sync across devices.
# Get a connection string from https://neon.tech or Vercel Storage → Postgres.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
