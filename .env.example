GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model. Translate app default is gemini-1.5-flash (better availability). Use gemini-1.5-pro for higher quality when not 503.
# GEMINI_MODEL=gemini-1.5-flash

# Translate app: JWT secret for session (use a long random string in production)
TRANSLATE_JWT_SECRET=your_secret_change_in_production
